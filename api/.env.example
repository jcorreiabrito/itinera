# Itinera API – environment variables (copy to .env or set in compose).
# No secrets are committed; set COUCHDB_PASSWORD via your secret store.

# --- CouchDB connection ---
COUCHDB_URL=http://couchdb:5984
COUCHDB_USER=admin
COUCHDB_PASSWORD=
COUCHDB_DB=itinera
HTTP_TIMEOUT_SECONDS=30

# --- Exports / backups ---
EXPORT_DIR=/data/exports
BACKUP_INTERVAL_HOURS=24
# BACKUP_CRON takes precedence over the interval when set, e.g. "0 3 * * *"
# BACKUP_CRON=
BACKUP_KEEP=14
COMPACT_ON_BACKUP=true

# --- App behaviour ---
SCHEDULER_ENABLED=true
# Comma-separated list; leave empty for same-origin only (recommended behind Caddy).
CORS_ORIGINS=
COUCH_READY_RETRIES=10
COUCH_READY_BACKOFF_SECONDS=2