# ===== Itinera – environment =====
# Copy this file to `.env` (which is gitignored) and adjust the values:
#   cp .env.example .env
#
# `docker compose` reads `.env` automatically from this folder.

# --- CouchDB admin credential (server-side only) ------------------------------
# The single admin user. The BROWSER never sees these; Caddy injects them as a
# Basic-auth header when proxying /db -> CouchDB. CHANGE THE PASSWORD.
COUCHDB_USER=admin
COUCHDB_PASSWORD=change-me-please

# --- Application database -----------------------------------------------------
# FastAPI creates this DB + its Mango indexes on startup. Keep as "itinera".
COUCHDB_DB=itinera

# --- Host networking ----------------------------------------------------------
# Host port to publish the app on -> open http://localhost:<HOST_HTTP_PORT>.
# Use 80 for a clean http://localhost. Change it if port 80 is already in use.
HOST_HTTP_PORT=80

# --- Misc ---------------------------------------------------------------------
# Container timezone (affects logs and scheduled exports).
TZ=UTC

# Disables FastAPI OpenAPI/Swagger/ReDoc in production; the app's code default
# is true for local dev.
DOCS_ENABLED=false